generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Consumption {
  id         String   @id @default(uuid())
  userId     String
  title      String   @db.VarChar(50)
  amount     Int
  category   Category
  keyword    Keyword
  emotion    Int
  consumedAt DateTime
  memo       String?  @db.VarChar(200)
  uploadId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("consumptions")
}

enum Category {
  FOOD
  TRANSPORT
  SHOPPING
  ENTERTAINMENT
  HEALTH
  OTHER
}

enum Keyword {
  STABLE
  IMPULSE
  STRESS
  REWARD
}
